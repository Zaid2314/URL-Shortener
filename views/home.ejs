<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>URL Shortener</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
min-height:100vh;
background:linear-gradient(135deg,#667eea,#764ba2);
display:flex;
justify-content:center;
align-items:flex-start;
padding:50px 20px;
}

/* Container */

.container{
width:95%;
max-width:900px;
padding:40px;
border-radius:15px;

background:rgba(255,255,255,0.15);
backdrop-filter:blur(15px);

box-shadow:0 10px 40px rgba(0,0,0,0.2);

color:white;
text-align:center;
}

h1{
font-weight:600;
margin-bottom:10px;
}

.subtitle{
opacity:0.8;
margin-bottom:30px;
font-size:14px;
}

/* Stats */

.stats{
display:flex;
gap:15px;
margin-bottom:30px;
}

.stat-card{
flex:1;
background:rgba(255,255,255,0.2);
padding:15px;
border-radius:10px;
}

.stat-card h2{
font-size:22px;
}

/* Input Section */

.input-box{
display:flex;
gap:10px;
justify-content:center;
margin-bottom:20px;
}

input{
flex:1;
padding:13px;
border:none;
border-radius:8px;
outline:none;
font-size:15px;
}

button{
padding:13px 18px;
border:none;
border-radius:8px;
background:#ff7a18;
color:white;
font-weight:500;
cursor:pointer;
transition:0.3s;
}

button:hover{
background:#ff5500;
transform:translateY(-2px);
}

/* Short URL box */

.short-url-box{
margin-top:20px;
padding:15px;
background:rgba(255,255,255,0.2);
border-radius:8px;
display:inline-block;
}

.copy-btn{
background:#00c853;
margin-left:10px;
padding:7px 12px;
}

.copy-btn:hover{
background:#00a844;
}

/* Table */

table{
margin-top:30px;
width:100%;
border-collapse:collapse;
background:white;
color:black;
border-radius:10px;
overflow:hidden;
box-shadow:0 5px 15px rgba(0,0,0,0.2);
}

th{
background:#667eea;
color:white;
padding:12px;
}

td{
padding:12px;
border-bottom:1px solid #eee;
text-align:center;
}

tr:hover{
background:#f4f4f4;
}

a{
color:#667eea;
text-decoration:none;
font-weight:500;
}

a:hover{
text-decoration:underline;
}

/* QR */

.qr-img{
width:60px;
height:60px;
}

/* Clear button */

.clear-btn{
margin-top:20px;
background:#e53935;
}

.clear-btn:hover{
background:#c62828;
}

/* Toast */

.toast{
position:fixed;
bottom:30px;
right:30px;
background:#333;
color:white;
padding:12px 18px;
border-radius:6px;
opacity:0;
transition:0.3s;
}

.toast.show{
opacity:1;
}

/* Responsive */

@media(max-width:700px){

.stats{
flex-direction:column;
}

.input-box{
flex-direction:column;
}

}

</style>
</head>

<body>

<div class="container">

<h1>🔗 URL Shortener</h1>
<p class="subtitle">Shorten long URLs instantly</p>

<!-- Stats -->

<%
let totalClicks = 0;
urls?.forEach(u => totalClicks += u.visitHistory.length)
%>

<div class="stats">

<div class="stat-card">
<h2><%= urls ? urls.length : 0 %></h2>
<p>Total URLs</p>
</div>

<div class="stat-card">
<h2><%= totalClicks %></h2>
<p>Total Clicks</p>
</div>

</div>

<% if (id) { %>

<div class="short-url-box">

<strong>Short URL:</strong>

<span id="shortUrl">
http://localhost:8001/url/<%= id %>
</span>

<button class="copy-btn" onclick="copyToClipboard()">
Copy
</button>

</div>

<% } %>

<form method="POST" action="/url">

<div class="input-box">

<input
type="text"
name="url"
placeholder="Paste your long URL here..."
required
>

<button type="submit">
🚀 Shorten
</button>

</div>

</form>

<% if (urls && urls.length > 0) { %>

<table>

<thead>
<tr>
<th>#</th>
<th>Short URL</th>
<th>Original URL</th>
<th>Clicks</th>
<th>QR Code</th>
</tr>
</thead>

<tbody>

<% urls.forEach((url,index)=>{ %>

<tr>

<td><%= index+1 %></td>

<td>
<a href="/url/<%= url.shortId %>" target="_blank">
http://localhost:8001/url/<%= url.shortId %>
</a>
</td>

<td><%= url.redirectUrl %></td>

<td><%= url.visitHistory.length %></td>

<td>
<img src="<%= url.qrCode %>" class="qr-img">
</td>

</tr>

<% }) %>

</tbody>

</table>

<form action="/clear-history" method="GET"
onsubmit="return confirm('Delete all URLs?');">

<button class="clear-btn">
Clear History
</button>

</form>

<% } %>

</div>

<div id="toast" class="toast">Copied!</div>

<script>

function copyToClipboard(){

const text=document.getElementById("shortUrl").innerText

navigator.clipboard.writeText(text)

const toast=document.getElementById("toast")

toast.classList.add("show")

setTimeout(()=>{
toast.classList.remove("show")
},2000)

}

</script>

</body>
</html>